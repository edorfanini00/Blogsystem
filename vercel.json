{
    "functions": {
        "api/index.js": {
            "includeFiles": "server/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/login",
            "destination": "/login.html"
        },
        {
            "source": "/signup",
            "destination": "/signup.html"
        }
    ]
}